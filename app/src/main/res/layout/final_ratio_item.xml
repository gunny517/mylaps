<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <import type="android.view.View"/>
        <variable
            name="item"
            type="jp.ceed.android.mylapslogger.model.FinalRatioItem" />
    </data>

    <TextView
        android:layout_width="@dimen/final_ratio_item_width"
        android:layout_height="@dimen/final_ratio_item_height"
        android:gravity="center"
        android:background="@{item.background}"
        android:textSize="@dimen/text_size_l"
        android:onClick="@{v -> item.changeSelected()}"
        android:text="@{item.text}"/>
</layout>